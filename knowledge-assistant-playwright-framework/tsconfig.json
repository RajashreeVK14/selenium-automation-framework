{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["node", "@playwright/test"]
  },
  "include": ["pages/**/*", "utils/**/*", "tests/**/*", "test-data/**/*"]
}
