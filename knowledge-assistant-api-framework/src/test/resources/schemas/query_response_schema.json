{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["answer", "citations"],
  "properties": {
    "answer": {
      "type": "string"
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "user": {
      "type": "object",
      "properties": {
        "region": { "type": "string" },
        "role": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
